# Database Configuration Template for NEON PostgreSQL
# Copy this file to .env and fill in your actual credentials

# Database Connection
DB_HOST=ep-your-neon-host.example.com
DB_PORT=5432
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=your_secure_password

# Connection String (optional - will be auto-generated from above)
SQLALCHEMY_DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@DB_HOST:DB_NAME?channel_binding=require&sslmode=require

# Connection Pool Settings (optimized for NEON)
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_RECYCLE=3600

# SSL Configuration (required for NEON)
SSL_MODE=require
CHANNEL_BINDING=require