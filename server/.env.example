# Database Configuration Template for NEON PostgreSQL
# Copy this file to .env and fill in your actual credentials

# Database Connection
DB_HOST=ep-your-neon-host.example.com
DB_PORT=5432
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=your_secure_password

# Connection String (optional - will be auto-generated from above)
SQLALCHEMY_DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@DB_HOST:DB_NAME?channel_binding=require&sslmode=require

# Connection Pool Settings (optimized for NEON)
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_RECYCLE=3600

# SSL Configuration (required for NEON)
SSL_MODE=require
CHANNEL_BINDING=require

# Authentication (NeonAuth / BetterAuth)
# Base URL of your BetterAuth instance (e.g. your Neon Auth endpoint)
NEON_AUTH_URL=https://your-auth-endpoint.neon.tech/api/auth
# API key for server-to-server calls (optional — only needed if BetterAuth requires it)
NEON_AUTH_API_KEY=

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173